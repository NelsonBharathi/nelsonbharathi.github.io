---
const profile = {
  name: "Your Name",
  role: "Your Job Title / Research Role",
  tagline: "Short, strong line about what you do (1–2 lines).",
  location: "Chennai, India",
  email: "yourmail@example.com",
  links: [
    { label: "GitHub", url: "https://github.com/nelsonbharathi" },
    { label: "LinkedIn", url: "https://linkedin.com/in/yourprofile" },
    { label: "Google Scholar", url: "#" },
    { label: "Website", url: "#" },
  ],
};
---

<aside class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
  <div class="flex items-start gap-4">
    <div class="h-16 w-16 shrink-0 overflow-hidden rounded-2xl border border-white/10 bg-white/10">
      <img
        src="/profile.jpg"
        alt="Profile"
        class="h-full w-full object-cover"
        onerror="this.style.display='none'"
      />
    </div>

    <div class="min-w-0">
      <h1 class="truncate text-lg font-semibold tracking-tight">{profile.name}</h1>
      <p class="text-sm text-white/70">{profile.role}</p>
      <p class="mt-2 text-sm text-white/70">{profile.tagline}</p>
    </div>
  </div>

  <div class="mt-5 space-y-2 text-sm text-white/70">
    <p><span class="text-white/90">Location:</span> {profile.location}</p>
    <p><span class="text-white/90">Email:</span> {profile.email}</p>
  </div>

  <div class="mt-5 grid grid-cols-2 gap-2">
    {profile.links.map((l) => (
      <a
        href={l.url}
        target="_blank"
        class="rounded-2xl border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/80 transition hover:bg-white/10 hover:text-white"
      >
        {l.label}
      </a>
    ))}
  </div>

  <div class="mt-6 rounded-2xl border border-white/10 bg-black/30 p-4 text-sm text-white/75">
    <p class="font-medium text-white/90">Quick summary</p>
    <p class="mt-2 leading-relaxed">
      Add a 2–4 line professional summary here. This will look great for recruiters and academics.
    </p>
  </div>
</aside>