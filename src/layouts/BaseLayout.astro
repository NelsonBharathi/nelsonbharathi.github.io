---
import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import ProfileSidebar from "../components/ProfileSidebar.astro";

const { title = "Portfolio", active = "home", description = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#05070f" />
  </head>

  <body class="min-h-screen text-white/90">
    <!-- background -->
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_20%_15%,rgba(99,102,241,0.22),transparent_42%),radial-gradient(circle_at_80%_20%,rgba(16,185,129,0.14),transparent_45%),radial-gradient(circle_at_40%_85%,rgba(236,72,153,0.12),transparent_48%)]"
      ></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.30),rgba(0,0,0,0.88))]"></div>
      <div class="absolute inset-0 opacity-[0.06] [background-image:radial-gradient(rgba(255,255,255,0.9)_1px,transparent_1px)] [background-size:18px_18px]"></div>
    </div>

    <TopNav active={active} />

    <main class="mx-auto w-full max-w-6xl px-4 py-6">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-[320px_1fr]">
        <ProfileSidebar />

        <section
          class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 backdrop-blur
                 shadow-[0_0_0_1px_rgba(255,255,255,0.06),0_20px_60px_-30px_rgba(0,0,0,0.75)]"
        >
          <slot />
        </section>
      </div>
    </main>

    <footer class="mx-auto max-w-6xl px-4 pb-10 text-sm text-white/55">
      <div class="mt-6 border-t border-white/10 pt-6">
        © {new Date().getFullYear()} — Built with Astro + Tailwind
      </div>
    </footer>
  </body>
</html>
