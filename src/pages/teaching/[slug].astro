---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DetailHeader from "../../components/DetailHeader.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("teaching");
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<BaseLayout title={`${item.data.title} | Teaching`} active="teaching">
  <DetailHeader
    title={item.data.title}
    description={item.data.description}
    tags={item.data.tags}
    links={item.data.links}
  />

  <div class="prose prose-invert max-w-none">
    <Content />
  </div>
</BaseLayout>