---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home | Portfolio" active="home" description="Professional portfolio">
  <div class="space-y-6">
    <div>
      <h2 class="text-xl font-semibold tracking-tight">Welcome</h2>
      <p class="mt-2 text-white/70 leading-relaxed">
        This is your homepage. It will show a strong professional overview, highlights,
        and quick links. We will make this more advanced in Part 5 (stats, featured cards, etc.).
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
        <p class="font-medium text-white/90">What you do</p>
        <p class="mt-2 text-sm text-white/70 leading-relaxed">
          Add a summary about your research/industry focus.
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/30 p-4">
        <p class="font-medium text-white/90">Highlights</p>
        <ul class="mt-2 list-disc pl-5 text-sm text-white/70 space-y-1">
          <li>1–2 key achievements</li>
          <li>1–2 awards or top projects</li>
          <li>1–2 publications or talks</li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
