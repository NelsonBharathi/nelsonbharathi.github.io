---
import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import ProfileSidebar from "../components/ProfileSidebar.astro";

const { title = "Portfolio", active = "home", description = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="theme-color" content="#05070f" />
  </head>

  <body class="min-h-screen bg-black text-white antialiased">
    <!-- Background (premium glow + vignette) -->
    <div class="pointer-events-none fixed inset-0 -z-10">
      <!-- glow blobs -->
      <div
        class="absolute inset-0 opacity-95"
        style="
          background:
            radial-gradient(900px 520px at 18% 12%, rgba(99,102,241,0.20), transparent 60%),
            radial-gradient(900px 520px at 82% 16%, rgba(16,185,129,0.16), transparent 60%),
            radial-gradient(1100px 680px at 50% 92%, rgba(236,72,153,0.12), transparent 60%);
          filter: blur(6px);
        "
      ></div>

      <!-- vignette -->
      <div
        class="absolute inset-0"
        style="
          background:
            linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.85));
        "
      ></div>

      <!-- subtle noise (optional but nice) -->
      <div
        class="absolute inset-0 opacity-[0.06] mix-blend-overlay"
        style="
          background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22140%22 height=%22140%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%222%22 stitchTiles=%22stitch%22/></filter><rect width=%22140%22 height=%22140%22 filter=%22url(%23n)%22 opacity=%220.7%22/></svg>');
        "
      ></div>
    </div>

    <!-- Top navigation -->
    <TopNav active={active} />

    <!-- Page content -->
    <main class="mx-auto w-full max-w-6xl px-4 py-6">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-[320px_1fr] md:gap-8">
        <!-- Sidebar -->
        <aside class="md:sticky md:top-6">
          <ProfileSidebar />
        </aside>

        <!-- Main card -->
        <section
          class="relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.06] p-5 shadow-[0_18px_45px_rgba(0,0,0,0.55)] backdrop-blur-xl sm:p-7"
        >
          <!-- inner highlight border -->
          <div
            class="pointer-events-none absolute inset-0 rounded-3xl"
            style="
              box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.10),
                inset 0 0 0 1px rgba(255,255,255,0.04);
            "
          ></div>

          <!-- content -->
          <div class="relative">
            <slot />
          </div>
        </section>
      </div>
    </main>

    <!-- Footer -->
    <footer class="mx-auto w-full max-w-6xl px-4 pb-10 text-sm text-white/60">
      <div class="mt-8 border-t border-white/10 pt-6 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>© {new Date().getFullYear()} — Built with Astro + Tailwind</div>
        <div class="text-white/40">
          Tip: Use <span class="text-white/60">Admin</span> to update content
        </div>
      </div>
    </footer>
  </body>
</html>
