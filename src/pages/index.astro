---
import BaseLayout from "../layouts/BaseLayout.astro";
import ItemCard from "../components/ItemCard.astro";
import ProfileSidebar from "../components/ProfileSidebar.astro";
import { getEntryBySlug, getCollection } from "astro:content";

// Read profile + settings from the "site" collection
const profileEntry = await getEntryBySlug("site", "profile");
const settingsEntry = await getEntryBySlug("site", "settings");

const profile = profileEntry?.data;
const settings = settingsEntry?.data;

// Collections for featured sections
const pubs = await getCollection("publications");
const projs = await getCollection("projects");

const featuredPubs = pubs.filter((p) => p.data.featured).slice(0, 4);
const featuredProjs = projs.filter((p) => p.data.featured).slice(0, 4);

// Optional hero background image
const heroBg = profile?.background || ""; // you can set this in profile.md if you want
---

<BaseLayout title={settings?.site_title ?? "Portfolio"}>
  {/* HERO */}
  <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-black/30">
    {heroBg && (
      <div class="absolute inset-0">
        <img src={heroBg} alt="" class="h-full w-full object-cover opacity-30" />
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/30"></div>
      </div>
    )}

    <div class="relative p-6 md:p-10">
      <div class="grid gap-6 md:grid-cols-[360px,1fr] md:items-start">
        {/* LEFT: Profile card (always reads site/profile.md) */}
        <ProfileSidebar />

        {/* RIGHT: Homepage content */}
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 md:p-8 shadow-lg backdrop-blur">
          <h1 class="text-2xl md:text-3xl font-semibold text-white">
            {settings?.home_heading ?? "Welcome"}
          </h1>
          <p class="mt-2 text-white/70">
            {settings?.home_subheading ??
              "This is your homepage. It shows a quick overview, featured highlights, and links to your work."}
          </p>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
              <div class="text-sm font-semibold text-white/90">What you do</div>
              <div class="mt-2 text-sm text-white/70">
                {settings?.home_card_left ??
                  "Add a summary about your research/industry focus."}
              </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
              <div class="text-sm font-semibold text-white/90">Highlights</div>
              <ul class="mt-2 space-y-1 text-sm text-white/70 list-disc pl-5">
                {(settings?.home_bullets ?? [
                  "1–2 key achievements",
                  "1–2 awards or top projects",
                  "1–2 publications",
                ]).map((b) => <li>{b}</li>)}
              </ul>
            </div>
          </div>

          {/* Featured Publications */}
          <div class="mt-8 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-white">Featured Publications</h2>
            <a href="/publications" class="text-sm text-white/70 hover:text-white">
              View all →
            </a>
          </div>

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {featuredPubs.length ? (
              featuredPubs.map((item) => (
                <ItemCard
                  title={item.data.title}
                  description={item.data.description}
                  href={`/publications/${item.slug}/`}
                  tags={item.data.tags}
                  links={item.data.links}
                />
              ))
            ) : (
              <div class="text-sm text-white/60">
                No featured publications yet. Open <b>/admin</b> → Publications → toggle <b>Featured</b>.
              </div>
            )}
          </div>

          {/* Featured Projects */}
          <div class="mt-8 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-white">Featured Projects</h2>
            <a href="/projects" class="text-sm text-white/70 hover:text-white">
              View all →
            </a>
          </div>

          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {featuredProjs.length ? (
              featuredProjs.map((item) => (
                <ItemCard
                  title={item.data.title}
                  description={item.data.description}
                  href={`/projects/${item.slug}/`}
                  tags={item.data.tags}
                  links={item.data.links}
                />
              ))
            ) : (
              <div class="text-sm text-white/60">
                No featured projects yet. Open <b>/admin</b> → Projects → toggle <b>Featured</b>.
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
