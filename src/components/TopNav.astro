---
const { active = "" } = Astro.props;

const base = import.meta.env.BASE_URL || "/";

const nav = [
  { key: "home", label: "Home", href: `${base}` },
  { key: "publications", label: "Publications", href: `${base}publications/` },
  { key: "teaching", label: "Teaching", href: `${base}teaching/` },
  { key: "projects", label: "Projects", href: `${base}projects/` },
  { key: "student-projects", label: "Student Projects", href: `${base}student-projects/` },
];

function isActive(key) {
  return active === key;
}
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-black/40 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a href={base} class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-xl bg-white/10">NB</span>
      <span class="text-sm md:text-base">Portfolio</span>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-xl px-3 py-2 text-sm transition",
            isActive(item.key)
              ? "bg-white/10 text-white"
              : "text-white/70 hover:bg-white/5 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`${base}admin/`}
        class="rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/80 transition hover:bg-white/10 hover:text-white"
      >
        Admin
      </a>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 pb-3 md:hidden">
    <div class="flex flex-wrap gap-2">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-xl px-3 py-2 text-xs transition",
            isActive(item.key)
              ? "bg-white/10 text-white"
              : "text-white/70 hover:bg-white/5 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>