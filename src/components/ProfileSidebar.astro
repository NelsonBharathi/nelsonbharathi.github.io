---
import { getEntryBySlug } from "astro:content";

const profileEntry = await getEntryBySlug("site", "profile");

const profile = profileEntry?.data ?? {
  name: "Your Name",
  role: "Your Job Title / Research Role",
  location: "Chennai, India",
  email: "yourmail@example.com",
  phone: "",
  bio: "Short, strong line about what you do (1–2 lines).",
  avatar: "/profile.jpg",
  links: [
    { label: "GitHub", url: "https://github.com/" },
    { label: "LinkedIn", url: "https://linkedin.com/" },
  ],
};

const avatar = profile.avatar || "/profile.jpg";
---
<aside class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-lg backdrop-blur">
  <div class="flex items-center gap-4">
    <img
      src={avatar}
      alt="Avatar"
      class="h-16 w-16 rounded-2xl object-cover ring-1 ring-white/10"
      loading="lazy"
    />
    <div>
      <div class="text-lg font-semibold text-white">{profile.name}</div>
      <div class="text-sm text-white/70">{profile.role}</div>
    </div>
  </div>

  <div class="mt-4 space-y-2 text-sm text-white/80">
    {profile.location && <div><span class="text-white/60">Location:</span> {profile.location}</div>}
    {profile.email && <div><span class="text-white/60">Email:</span> {profile.email}</div>}
    {profile.phone && <div><span class="text-white/60">Phone:</span> {profile.phone}</div>}
  </div>

  {profile.links?.length ? (
    <div class="mt-4 grid grid-cols-2 gap-2">
      {profile.links.map((l) => (
        <a
          href={l.url}
          target="_blank"
          rel="noreferrer"
          class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-center text-sm text-white/90 hover:bg-white/10"
        >
          {l.label}
        </a>
      ))}
    </div>
  ) : null}

  {profile.bio ? (
    <div class="mt-5 rounded-2xl border border-white/10 bg-black/20 p-4 text-sm text-white/80">
      <div class="mb-1 font-semibold text-white/90">Quick summary</div>
      <div>{profile.bio}</div>
    </div>
  ) : null}
</aside>
