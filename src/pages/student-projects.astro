---
import BaseLayout from "../layouts/BaseLayout.astro";
import ItemCard from "../components/ItemCard.astro";
import { getCollection } from "astro:content";

const items = await getCollection("student-projects");
items.sort((a, b) => (b.data.date?.valueOf?.() ?? 0) - (a.data.date?.valueOf?.() ?? 0));
---

<BaseLayout title="Student Projects | Portfolio" active="student-projects">
  <div class="flex items-end justify-between gap-4">
    <div>
      <h2 class="text-xl font-semibold tracking-tight">Student Projects</h2>
      <p class="mt-2 text-white/70">Projects developed by students with supervision and outcomes.</p>
    </div>
    <div class="text-sm text-white/60">{items.length} items</div>
  </div>

  <div class="mt-6 grid gap-4">
    {items.map((item) => (
      <ItemCard
        title={item.data.title}
        description={item.data.description}
        tags={item.data.tags}
        links={item.data.links}
        href={`/student-projects/${item.slug}/`}
      />
    ))}
  </div>
</BaseLayout>