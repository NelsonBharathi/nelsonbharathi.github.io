---
const { title, description, href, tags = [], links = [] } = Astro.props;

function kindStyles(kind) {
  switch (kind) {
    case "download":
      return "border-emerald-400/20 bg-emerald-500/10 text-emerald-100 hover:bg-emerald-500/15";
    case "view":
      return "border-indigo-400/20 bg-indigo-500/10 text-indigo-100 hover:bg-indigo-500/15";
    default:
      return "border-white/10 bg-white/5 text-white/80 hover:bg-white/10";
  }
}
---

<article class="group rounded-3xl border border-white/10 bg-black/25 p-5 transition hover:bg-black/35">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <a href={href} class="block">
        <h3 class="truncate text-base font-semibold tracking-tight text-white group-hover:text-white">
          {title}
        </h3>
      </a>
      <p class="mt-2 text-sm text-white/70 leading-relaxed">{description}</p>
    </div>
  </div>

  {tags?.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((t) => (
        <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-xs text-white/70">
          {t}
        </span>
      ))}
    </div>
  )}

  <div class="mt-5 flex flex-wrap gap-2">
    <a
      href={href}
      class="rounded-2xl border border-white/10 bg-white/5 px-3 py-2 text-sm text-white/80 transition hover:bg-white/10 hover:text-white"
    >
      Read More
    </a>

    {links?.slice(0, 3).map((l) => (
      <a
        href={l.url}
        target={l.url.startsWith("http") ? "_blank" : undefined}
        class:list={[
          "rounded-2xl border px-3 py-2 text-sm transition",
          kindStyles(l.kind),
        ]}
      >
        {l.label}
      </a>
    ))}
  </div>
</article>