<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Admin</title>

    <!-- ✅ Fallback: if worker redirects back with #github_token=..., store it for Decap -->
    <script>
  (function () {
    try {
      var hash = window.location.hash || "";
      var m = hash.match(/github_token=([^&]+)/);
      if (!m) return;

      var token = decodeURIComponent(m[1]);

      // Store in BOTH keys (Decap / Netlify CMS variants)
      var userObj = JSON.stringify({ token: token, backendName: "github" });
      localStorage.setItem("netlify-cms-user", userObj);
      localStorage.setItem("decap-cms-user", userObj);

      // Clean URL
      history.replaceState(null, document.title, window.location.pathname);

      // Force reload so Decap reads storage again
      window.location.reload();
    } catch (e) {}
  })();
</script>

    <!-- Decap CMS -->
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

    <style>
      body { margin: 0; }
    </style>
  </head>

  <body></body>
</html>