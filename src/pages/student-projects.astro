---
import BaseLayout from "../layouts/BaseLayout.astro";
import ItemCard from "../components/ItemCard.astro";
import FilterBar from "../components/FilterBar.astro";
import { getCollection } from "astro:content";

const items = await getCollection("student-projects");

items.sort((a, b) => {
  const da = a.data.date ? new Date(a.data.date).getTime() : 0;
  const db = b.data.date ? new Date(b.data.date).getTime() : 0;
  return db - da;
});

const allTags = Array.from(
  new Set(items.flatMap((i) => i.data.tags ?? []))
).sort();
---

<BaseLayout title="Student Projects">
  <h1 class="text-3xl font-semibold tracking-tight">Student Projects</h1>
  <p class="mt-2 text-white/70">
    Student projects with detailed pages and optional view/download links.
  </p>

  <FilterBar allTags={allTags} />

  <div class="mt-6 grid md:grid-cols-2 gap-4">
    {items.map((item) => (
      <div
        data-card
        data-text={`${item.data.title} ${item.data.description}`}
        data-tags={(item.data.tags ?? []).join(",")}
      >
        <ItemCard
          title={item.data.title}
          description={item.data.description}
          href={`/student-projects/${item.slug}/`}
          tags={item.data.tags}
          links={item.data.links}
        />
      </div>
    ))}
  </div>
</BaseLayout>