<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Admin</title>

    <!-- ✅ Fallback: if worker redirects back with #github_token=..., store it for Decap -->
    <script>
      (function () {
        try {
          var hash = window.location.hash || "";
          var m = hash.match(/github_token=([^&]+)/);
          if (!m) return;

          var token = decodeURIComponent(m[1]);

          // Decap/Netlify CMS reads token from localStorage key 'netlify-cms-user'
          // This format works for the github backend.
          localStorage.setItem(
            "netlify-cms-user",
            JSON.stringify({ token: token, backendName: "github" })
          );

          // Clean up the URL (remove token from address bar)
          history.replaceState(null, document.title, window.location.pathname);
        } catch (e) {}
      })();
    </script>

    <!-- Decap CMS -->
    <script src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

    <style>
      body { margin: 0; }
    </style>
  </head>

  <body></body>
</html>