---
import "../styles/global.css";
import TopNav from "../components/TopNav.astro";
import ProfileSidebar from "../components/ProfileSidebar.astro";

const { title = "Portfolio", active = "home", description = "" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <meta name="theme-color" content="#05070f" />
  </head>

  <body>
    <!-- background -->
    <div class="pointer-events-none fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_15%,rgba(99,102,241,0.18),transparent_40%),radial-gradient(circle_at_80%_20%,rgba(16,185,129,0.10),transparent_40%),radial-gradient(circle_at_40%_80%,rgba(236,72,153,0.10),transparent_45%)]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.35),rgba(0,0,0,0.85))]"></div>
    </div>

    <TopNav active={active} />

    <main class="mx-auto grid max-w-6xl grid-cols-1 gap-6 px-4 py-6 md:grid-cols-[320px_1fr]">
      <ProfileSidebar />
      <section class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
        <slot />
      </section>
    </main>

    <footer class="mx-auto max-w-6xl px-4 pb-10 text-sm text-white/50">
      <div class="mt-6 border-t border-white/10 pt-6">
        © {new Date().getFullYear()} — Built with Astro + Tailwind
      </div>
    </footer>
  </body>
</html>